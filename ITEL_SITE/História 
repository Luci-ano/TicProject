            font-size: 1.2rem;
            margin-top: 1.2rem;
            border: 1px solid rgba(255, 215, 100, 0.4);
            color: #f9e9c7;
        }

        .conteudo {
            padding: 2.5rem 3rem;
        }

        .secao {
            margin-bottom: 2.5rem;
            border-bottom: 1px solid #e2eaf1;
            padding-bottom: 2rem;
        }

        .secao:last-child {
            border-bottom: 0;
            margin-bottom: 0;
            padding-bottom: 0;
        }

        h2 {
            font-size: 1.9rem;
            font-weight: 600;
            color: #003153;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        h2 span {
            background: #f0b72f;
            color: #003153;
            padding: 0.2rem 0.7rem;
            border-radius: 30px;
            font-size: 1rem;
            font-weight: 600;
            margin-left: 0.75rem;
        }

        h3 {
            font-size: 1.3rem;
            font-weight: 600;
            color: #0f4c6b;
            margin: 1.5rem 0 0.8rem 0;
        }

        p {
            margin-bottom: 1.2rem;
            font-size: 1.1rem;
            color: #1f3a4f;
        }

        .destaque {
            background: #e8f0fe;
            padding: 1.5rem 2rem;
            border-radius: 24px;
            margin: 1.8rem 0;
            border-left: 6px solid #f0b72f;
        }

        .destaque p:last-child {
            margin-bottom: 0;
        }

        ul {
            list-style: none;
            margin: 1rem 0 1.5rem 0;
        }

        li {
            padding: 0.5rem 0 0.5rem 2rem;
            background: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="%23003153"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>') left center no-repeat;
            background-size: 1.2rem;
            font-size: 1.05rem;
        }

        .diretores {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            margin-top: 0.5rem;
        }

        .diretor-card {
            background: #f6faff;
            border-radius: 60px;
            padding: 0.5rem 1.5rem;
            border: 1px solid #cbd6e6;
            font-weight: 500;
            box-shadow: 0 2px 6px rgba(0,35,70,0.05);
        }

        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1.2rem;
            margin: 1.5rem 0;
        }

        .info-item {
            background: white;
            border: 1px solid #d9e2ef;
            border-radius: 20px;
            padding: 1.2rem 1rem;
            text-align: center;
            font-weight: 500;
            box-shadow: 0 4px 10px rgba(0,30,60,0.03);
        }

        .info-item strong {
            display: block;
            font-size: 1.3rem;
            color: #003153;
            margin-bottom: 0.2rem;
        }

        .tag {
            background: #003153;
            color: white;
            padding: 0.2rem 1rem;
            border-radius: 30px;
            font-size: 0.9rem;
            font-weight: 600;
            display: inline-block;
            margin-right: 0.5rem;
            margin-bottom: 0.5rem;
        }

        .site {
            background: #1c3b5e;
            color: white;
            text-decoration: none;
            font-weight: 600;
            padding: 0.8rem 2rem;
            border-radius: 40px;
            display: inline-block;
            margin-top: 1rem;
            transition: 0.2s;
            border: 1px solid rgba(255,215,0,0.3);
        }

        .site:hover {
            background: #0a4b78;
            transform: scale(1.02);
            box-shadow: 0 8px 18px rgba(0,80,120,0.3);
        }

        footer {
            background: #eef3f9;
            padding: 1.5rem 3rem;
            text-align: center;
            color: #345a7a;
            border-top: 1px solid #cbdae9;
